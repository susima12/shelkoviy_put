# ═══════════════════════════════════════════════════════════════
# Шёлковый путь — переменные окружения (SQLite, без Supabase)
# Скопируйте: copy .env.example .env
# ═══════════════════════════════════════════════════════════════

# Секрет для JWT-токенов (обязательно смените в production!)
JWT_SECRET=замените-на-длинный-случайный-ключ-минимум-32-символа

# Путь к файлу SQLite (локально — data/festival.db)
DATABASE_PATH=./data/festival.db

# Render задаёт PORT автоматически
# PORT=3000
# NODE_ENV=production

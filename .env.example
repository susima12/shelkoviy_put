# ═══════════════════════════════════════════════════════════════
# Шёлковый путь — переменные окружения
# Скопируйте в .env для локальной разработки:
#   copy .env.example .env
# На Render — добавьте те же переменные в Dashboard → Environment
# ═══════════════════════════════════════════════════════════════

# ── Supabase (сервер + сборка) ────────────────────────────────
# Project Settings → API → Project URL
SUPABASE_URL=https://ВАШ_PROJECT_ID.supabase.co
VITE_SUPABASE_URL=https://ВАШ_PROJECT_ID.supabase.co

# Project Settings → API → anon public
SUPABASE_PUBLISHABLE_KEY=eyJ...
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...

# Project Settings → General → Reference ID (только project id)
VITE_SUPABASE_PROJECT_ID=ваш_project_id

# Project Settings → API → service_role (ТОЛЬКО на сервере, НЕ в браузере!)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Render (опционально, Render задаёт сам) ───────────────────
# PORT=3000
# NODE_ENV=production
